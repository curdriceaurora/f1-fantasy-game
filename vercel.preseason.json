{
  "redirects": [
    {
      "source": "/",
      "destination": "/index.html",
      "permanent": false
    },
    {
      "source": "/dashboard.html",
      "destination": "/index.html",
      "permanent": false
    },
    {
      "source": "/team.html",
      "destination": "/index.html",
      "permanent": false
    }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "{data/**,season/**}"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
