{
  "name": "f1-fantasy-game",
  "version": "1.0.0",
  "description": "F1 Fantasy Team Selector — PocketTanks Game + Slot Machine",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "lint": "eslint .",
    "quality:check": "npm run lint && npm run test",
    "test": "node --test",
    "test:generate-corpus": "node scripts/generate-test-corpus.mjs",
    "sync:entries": "node scripts/sync-season-entries.mjs",
    "score:race": "node scripts/score-race.mjs",
    "auto:score": "node scripts/auto-score.mjs",
    "switch-mode": "node scripts/switch-mode.mjs",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "simple-git-hooks": "^2.13.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint"
  }
}
